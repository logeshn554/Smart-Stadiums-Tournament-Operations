# StadiumOps AI — Environment Configuration
# Copy this file to .env and fill in real values

# Google Gemini API Key (required for GenAI features)
GEMINI_API_KEY=your-gemini-api-key-here

# Allowed CORS origins (comma-separated)
# Update with your deployed frontend URL
CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com,http://localhost:8000,http://127.0.0.1:8000

# Application environment
APP_ENV=production

# API rate limit (requests per minute)
RATE_LIMIT_PER_MINUTE=10

# Server host and port
HOST=0.0.0.0
PORT=8000

# Redis URL for distributed rate limiting (optional; falls back to in-memory)
# REDIS_URL=redis://localhost:6379/0

# JWT token expiry in minutes (default: 60)
JWT_EXPIRE_MINUTES=60

# Rate limiter backend: "memory" (default) or "redis" (requires REDIS_URL)
RATE_LIMIT_BACKEND=memory

# Firebase Cloud Messaging Config (Optional, free and no credit card required)
FCM_SERVER_KEY=your-fcm-server-key-here
FIREBASE_API_KEY=your-firebase-api-key-here
FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain-here
FIREBASE_PROJECT_ID=your-firebase-project-id-here
FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket-here
FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id-here
FIREBASE_APP_ID=your-firebase-app-id-here
FIREBASE_VAPID_KEY=your-firebase-vapid-key-here
