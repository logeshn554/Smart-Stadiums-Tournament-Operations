# StadiumOps AI — Environment Configuration
# Copy this file to .env and fill in real values

# Google Gemini API Key (required for GenAI features)
GEMINI_API_KEY=your-gemini-api-key-here

# Allowed CORS origins (comma-separated)
# Update with your deployed frontend URL
CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com,http://localhost:8000,http://127.0.0.1:8000

# Application environment
APP_ENV=production

# API rate limit (requests per minute)
RATE_LIMIT_PER_MINUTE=10

# Server host and port
HOST=0.0.0.0
PORT=8000

# Redis URL for distributed rate limiting (optional; falls back to in-memory)
# REDIS_URL=redis://localhost:6379/0

# JWT token expiry in minutes (default: 60)
JWT_EXPIRE_MINUTES=60

# Rate limiter backend: "memory" (default) or "redis" (requires REDIS_URL)
RATE_LIMIT_BACKEND=memory
