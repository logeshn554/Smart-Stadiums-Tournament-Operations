# StadiumOps AI — Environment Configuration
# Copy this file to .env and fill in real values

# Allowed CORS origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:8080,http://127.0.0.1:8080,null

# Application environment
APP_ENV=development

# API rate limit (requests per minute)
RATE_LIMIT_PER_MINUTE=10

# Server host and port
HOST=127.0.0.1
PORT=8000

# Redis URL for distributed rate limiting (optional; falls back to in-memory)
# REDIS_URL=redis://localhost:6379/0

# JWT token expiry in minutes (default: 60)
JWT_EXPIRE_MINUTES=60

# Rate limiter backend: "memory" (default) or "redis" (requires REDIS_URL)
RATE_LIMIT_BACKEND=memory
